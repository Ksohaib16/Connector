<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connector</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.1.1/css/all.min.css">
    <link rel="stylesheet" href="/css/register.css">
</head>
<body>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <div id="app" class="container-fluid  d-flex justify-content-center align-items-center min-vh-100">
        <div class="inner-box container col-8">
            <div class="row align-items-center">
                <div class="col-12 header">
                    <h1>Connector</h1>
                    <p>Let's really connect</p>
                </div>
            </div>
            <div id="authContainer" class="row auth-container">
                <div class="col-6">
                    <div class="card shadow-lg">
                        <div class="card-body">
                            <h1 class="card-title text-left mb-3" id="authTitle">Login</h1>
                            <form action="/api/auth/login" method="POST" id="loginForm" class="needs-validation" novalidate >
                                <div class="mb-3">
                                    <label for="email" class="form-label">Email</label>
                                    <input type="email" name="email" class="form-control" id="loginEmail" placeholder="user@gmail.com" required>
                                </div>
                                <div class="mb-2">
                                    <label for="password" class="form-label">Password</label>
                                    <input type="password"  name="password" class="form-control" id="loginPassword" placeholder="Password" required>
                                </div>
                                <div class="forgot d-flex">
                                    <span class="">Forgot Password?</span>
                                </div>
                                <button type="submit" class="btn w-100" id="authButton">Login</button>
                            </form>
                            <div class="auth">
                                <span>Don't have an account?</span>
                                <a href="/api/auth/signup" id="toggleAuth">Signup</a>
                            </div>

                        </div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="hero-area">
                        <div class="hero-image">
                        </div>
                        <br>
                        <div class="hero-content">
                            <h4>A Messenger with Super Powers</h4>
                             <p>"Connector" is a messenger web app designed to litreally connect everyone on planet Earth</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="/cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/register.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

</body>
</html>


